<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/primaryText"
        android:text="编辑知识点"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- 标题 -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="标题"
        app:boxStrokeColor="@color/primary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textSize="15sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 大类分类 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="分类"
        android:textSize="13sp"
        android:textColor="@color/secondaryText"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rb_character"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="人物"
            android:textSize="13sp" />

        <RadioButton
            android:id="@+id/rb_place"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="地点"
            android:textSize="13sp" />

        <RadioButton
            android:id="@+id/rb_event"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="事件"
            android:textSize="13sp" />

        <RadioButton
            android:id="@+id/rb_note"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="笔记"
            android:textSize="13sp" />

        <RadioButton
            android:id="@+id/rb_other"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="其他"
            android:textSize="13sp"
            android:checked="true" />

    </RadioGroup>

    <!-- 人物子分类（仅当 rb_character 选中时可见） -->
    <LinearLayout
        android:id="@+id/layout_sub_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="人物子类"
            android:textSize="13sp"
            android:textColor="@color/secondaryText"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <RadioGroup
            android:id="@+id/rg_sub_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rb_sub_classic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="经典角色"
                android:textSize="13sp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rb_sub_novel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="小说角色"
                android:textSize="13sp" />

        </RadioGroup>

        <!-- 小说名（仅当小说角色选中时可见） -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_novel_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="小说名"
            android:visibility="gone"
            android:layout_marginTop="4dp"
            app:boxStrokeColor="@color/primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_novel_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- 内容 -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:hint="内容"
        app:boxStrokeColor="@color/primary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:textSize="14sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 保存 -->
    <!-- 操作按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="删除"
            android:textColor="@android:color/holo_red_dark"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="保存"
            android:textSize="15sp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
